# Local: copie para .env
# Hostinger → Environment variables (painel Node.js):

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
NODE_ENV=production


# Banco de dados (Prisma)
# Projeto configurado para MySQL com Prisma.
# No Hostinger, o servidor de banco normalmente é 127.0.0.1:3306.
# Exemplo pronto para editar (substitua SUA_SENHA_ESCAPED pelo valor percent-encoded se necessário):
# DATABASE_URL="mysql://u681328529_Brazugdb:QWEqwe123!@#@127.0.0.1:3306/u681328529_Brazug"
#
# Se o painel Hostinger fornecer outro host/porta, substitua 127.0.0.1:3306 pelo host/porta fornecidos.
# Alternativa com host genérico:
# DATABASE_URL="mysql://usuario:senha@host:3306/database"

# Local dev sem banco disponível:
# SKIP_DB_PUSH=1
#
# Se o build falhar com P1000 (credentials inválidas), corrija a URL do banco
# no painel Hostinger e use SKIP_DB_PUSH=1 apenas temporariamente.
#
# Opcional:
# ADMIN_SECRET=outro_segredo_para_tokens
# DATABASE_PATH=/caminho/brazug.db

# Hostinger build/start:
#   Build: npm run build
#   Start: npm start
#   Output: .
#   Entry: server.js
