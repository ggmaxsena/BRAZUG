# Local: copie para .env
# Hostinger → Environment variables (painel Node.js):

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
NODE_ENV=production
MONGODB_URI=mongodb+srv://usuario:<senha>@cluster0.exemplo.mongodb.net/Brazug?retryWrites=true&w=majority
MONGODB_DB=Brazug

# Obrigatório: MongoDB Atlas (aventuras e usuários do admin).
#
# Hostinger: se der ENOTFOUND/querySrv com mongodb+srv, use no painel Node.js:
#   1) Atlas → Connect → Drivers → tipo "Standard" (não SRV)
#   2) Cole em MONGODB_URI_STANDARD= (mongodb://... com porta 27017)
# Ou mantenha MONGODB_URI e deixe o DNS público (já aplicado no código):
#   MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
#   MONGODB_IPV4=1
#
# Opcional:
# ADMIN_SECRET=outro_segredo_para_tokens

# Hostinger build/start:
#   Build: npm run build
#   Start: npm start
#   Output: .
#   Entry: server.js
