# Local: copie para .env
# Hostinger → Environment variables (painel Node.js):

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
NODE_ENV=production
MONGODB_URI=mongodb+srv://usuario:<senha>@cluster0.exemplo.mongodb.net/Brazug?retryWrites=true&w=majority
MONGODB_DB=Brazug

# Obrigatório: MongoDB Atlas (aventuras e usuários do admin).
#
# Hostinger: cluster0.xxx.mongodb.net NÃO tem registro A (só SRV).
# O app converte mongodb+srv automaticamente no boot.
# Se ainda falhar, gere a URI Standard no PC e cole no painel:
#   npm run mongo:standard-uri
#   → copie MONGODB_URI_STANDARD= para Hostinger → Environment variables
#
# Opcional:
# ADMIN_SECRET=outro_segredo_para_tokens

# Hostinger build/start:
#   Build: npm run build
#   Start: npm start
#   Output: .
#   Entry: server.js
