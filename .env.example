# Local: copie para .env
# Hostinger → Environment variables (painel Node.js):

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
NODE_ENV=production


# O projeto agora usa armazenamento local JSON para aventuras.
# Não é necessário configurar DATABASE_URL nem MySQL.
#
# Se você quiser usar um banco diferente no futuro, adapte lib/db.cjs.
#
# Opcional:
# ADMIN_SECRET=outro_segredo_para_tokens

# Hostinger build/start:
#   Build: npm run build
#   Start: npm start
#   Output: .
#   Entry: server.js
