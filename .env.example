# Local: copie para .env
# Hostinger → Environment variables (painel Node.js):

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
NODE_ENV=production
MONGODB_URI=mongodb+srv://usuario:<senha>@cluster0.exemplo.mongodb.net/Brazug?retryWrites=true&w=majority
MONGODB_DB=Brazug

# Obrigatório: MongoDB Atlas (aventuras e usuários do admin).
#
# Hostinger — use APENAS UMA das opções abaixo:
#
# Opção A (recomendada): só MONGODB_URI com mongodb+srv (o app converte no boot)
# Opção B: MONGODB_URI_STANDARD com mongodb://... Standard do Atlas (NÃO use srv aqui)
# Opção C: se SRV falhar no servidor, defina também:
#   MONGODB_SHARD_HOSTS=shard-00-00.xxx.mongodb.net:27017,shard-00-01...,shard-00-02...
#   MONGODB_REPLICA_SET=atlas-xxxxx-shard-0
#
# Atlas → Network Access → 0.0.0.0/0 (obrigatório se aparecer SSL alert 80)
#
# Gerar URI Standard no PC: npm run mongo:standard-uri
#
# Opcional:
# ADMIN_SECRET=outro_segredo_para_tokens

# Hostinger build/start:
#   Build: npm run build
#   Start: npm start
#   Output: .
#   Entry: server.js
