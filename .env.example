# Local: copie para .env
#
# Hostinger → Settings and redeploy:
#   Build command:     npm run build
#   Start command:     npm start
#   Output directory:  dist
#   Entry file:        server.js
#   Environment vars:  TWITCH_CLIENT_ID, TWITCH_CLIENT_SECRET, NODE_ENV=production
#   (não defina PORT no painel)
#
# https://dev.twitch.tv/console/apps

TWITCH_CLIENT_ID=seu_client_id_aqui
TWITCH_CLIENT_SECRET=seu_client_secret_aqui
# PORT — na Hostinger é definido automaticamente; não defina PORT manualmente no painel
NODE_ENV=production
