# App Node (Hostinger ou local) — NÃO use na VPS do Postgres

PORT=3000

# IP ou hostname da VPS onde roda o docker compose (só o banco)
DATABASE_URL=postgresql://brazug:SENHA@IP_DA_VPS:5432/brazug

# Ou variáveis separadas:
# POSTGRES_HOST=IP_DA_VPS
# POSTGRES_PORT=5432
# POSTGRES_USER=brazug
# POSTGRES_PASSWORD=SENHA
# POSTGRES_DB=brazug

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
GUILD_SECRET=palavra_passe_cadastro_guilda
NODE_ENV=production
