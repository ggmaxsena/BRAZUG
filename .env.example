# Local: copie para .env
# Hostinger → Environment variables (painel Node.js):

TWITCH_CLIENT_ID=seu_client_id
TWITCH_CLIENT_SECRET=seu_client_secret
ADMIN_PASSWORD=senha_forte_admin_aqui
NODE_ENV=production
MONGODB_URI=mongodb+srv://exssgg_db_user:<senha>@cluster0.exemplo.mongodb.net/Brazug?retryWrites=true&w=majority
MONGODB_DB=Brazug

# O projeto agora usa MongoDB Atlas para armazenar aventuras.
# Se não definir MONGODB_URI, ele continuará usando o armazenamento local JSON.
#
# Opcional:
# ADMIN_SECRET=outro_segredo_para_tokens

# Hostinger build/start:
#   Build: npm run build
#   Start: npm start
#   Output: .
#   Entry: server.js
